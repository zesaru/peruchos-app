{
  "expo": {
    "name": "Perucho's App",
    "slug": "peruchos-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "landscape",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6DEDD"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6DEDD"
      },
      "package": "com.peruchos.plebeyusapp",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Perucho's App to access the camera for table QR setup."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "556f47dc-3cab-40da-91a1-807de38f1b79"
      }
    },
    "owner": "zesaru"
  }
}
